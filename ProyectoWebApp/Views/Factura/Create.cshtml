
@{
    ViewData["Title"] = "Crear Factura";
}

<!-- (fragmento relevante: añadimos campo para Id Mesa) -->
<div class="row mb-3">
    <div class="col-md-4">
        <label>Cliente</label>
        <select id="clienteId" class="form-select">...</select>
    </div>
    <div class="col-md-4">
        <label>Mesero</label>
        <select id="meseroId" class="form-select">...</select>
    </div>
    <div class="col-md-4">
        <label>Mesa (opcional)</label>
        <input id="mesaId" type="number" min="0" class="form-control" placeholder="Id mesa (ej. 1)" />
    </div>
</div>

<script>
// al crear payload incluimos mesaId
document.getElementById('submitBtn').addEventListener('click', async () => {
    const clienteId = parseInt(document.getElementById('clienteId').value || '0');
    const meseroId = parseInt(document.getElementById('meseroId').value || '0');
    const mesaId = parseInt(document.getElementById('mesaId').value || '0') || null;

    const lineas = [];
    document.querySelectorAll('#lineasTable tbody tr').forEach(tr => {
        const sel = tr.querySelector('.plato-select');
        const platoId = parseInt(sel ? sel.value || '0' : '0');
        const cantidad = parseInt(tr.querySelector('.cantidad-input').value || '1');
        const precio = parseFloat(tr.querySelector('.precio-input').value || '0');
        if (platoId > 0 && cantidad > 0) {
            lineas.push({ platoId: platoId, cantidad: cantidad, precio: precio });
        }
    });

    const payload = {
        clienteId: clienteId,
        meseroId: meseroId,
        mesaId: mesaId,           // <-- añadido
        fecha: new Date().toISOString(),
        lineas: lineas
    };

    const resp = await fetch('/Factura/Create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });

    if (resp.redirected) {
        window.location = resp.url;
    } else {
        const text = await resp.text();
        alert('Error al crear factura: ' + resp.status + ' ' + text);
    }
});
</script>