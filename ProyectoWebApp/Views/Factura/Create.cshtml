@model ProyectoWebApp.Models.FacturaCreateViewModel
@{
    ViewData["Title"] = "Crear Factura";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container py-4">
    <h2>Crear Factura</h2>

    <form id="facturaForm">
        <div class="row mb-3">
            <div class="col-md-6">
                <label>Cliente</label>
                <select id="clienteId" class="form-select">
                    <option value="">-- Seleccione --</option>
                    @foreach (var c in Model.Clientes ?? Enumerable.Empty<object>())
                    {
                        <option value="@((int) (c.GetType().GetProperty("id")?.GetValue(c) ?? 0))">
                            @c.GetType().GetProperty("nombres")?.GetValue(c)
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label>Mesero</label>
                <select id="meseroId" class="form-select">
                    <option value="">-- Seleccione --</option>
                    @foreach (var m in Model.Meseros ?? Enumerable.Empty<object>())
                    {
                        <option value="@((int)(m.GetType().GetProperty("idMesero")?.GetValue(m) ?? 0))">
                            @m.GetType().GetProperty("nombres")?.GetValue(m) @m.GetType().GetProperty("apellidos")?.GetValue(m)
                        </option>
                    }
                </select>
            </div>
        </div>

        <h5>Platos</h5>
        <table class="table" id="lineasTable">
            <thead>
                <tr>
                    <th>Plato</th><th>Cantidad</th><th>Precio</th><th></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>

        <div class="mb-3">
            <button type="button" id="addLineaBtn" class="btn btn-primary">Agregar plato</button>
        </div>

        <div>
            <button type="button" id="submitBtn" class="btn btn-success">Guardar Factura</button>
            <a class="btn btn-secondary" asp-action="Index">Cancelar</a>
        </div>
    </form>
</div>

<script>
    const platos = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Platos ?? new object[0]));
    function createPlatoSelect() {
        const select = document.createElement('select');
        select.className = 'form-select plato-select';
        select.innerHTML = '<option value="">--Seleccione--</option>';
        for (const p of platos) {
            const opt = document.createElement('option');
            // Intenta obtener propiedades comunes (ajusta nombres según tu API)
            opt.value = p.idPlato ?? p.id ?? 0;
            opt.textContent = (p.nombre ?? p.nombrePlato ?? p.nombrePlato);
            opt.dataset.precio = p.precio ?? 0;
            select.appendChild(opt);
        }
        return select;
    }

    document.getElementById('addLineaBtn').addEventListener('click', () => {
        const tbody = document.querySelector('#lineasTable tbody');
        const tr = document.createElement('tr');

        const tdPlato = document.createElement('td');
        tdPlato.appendChild(createPlatoSelect());

        const tdCant = document.createElement('td');
        const inputCant = document.createElement('input');
        inputCant.type = 'number';
        inputCant.min = 1;
        inputCant.value = 1;
        inputCant.className = 'form-control cantidad-input';
        tdCant.appendChild(inputCant);

        const tdPrecio = document.createElement('td');
        const inputPrecio = document.createElement('input');
        inputPrecio.type = 'number';
        inputPrecio.step = '0.01';
        inputPrecio.className = 'form-control precio-input';
        inputPrecio.readOnly = true;
        tdPrecio.appendChild(inputPrecio);

        const tdAcc = document.createElement('td');
        const btnDel = document.createElement('button');
        btnDel.type = 'button';
        btnDel.className = 'btn btn-danger btn-sm';
        btnDel.textContent = 'Eliminar';
        btnDel.addEventListener('click', () => tr.remove());
        tdAcc.appendChild(btnDel);

        tr.appendChild(tdPlato);
        tr.appendChild(tdCant);
        tr.appendChild(tdPrecio);
        tr.appendChild(tdAcc);
        tbody.appendChild(tr);

        // actualizar precio al seleccionar plato
        tdPlato.querySelector('select').addEventListener('change', (e) => {
            const sel = e.target;
            const precio = sel.options[sel.selectedIndex].dataset.precio || 0;
            inputPrecio.value = precio;
        });
    });

    document.getElementById('submitBtn').addEventListener('click', async () => {
        const clienteId = parseInt(document.getElementById('clienteId').value || '0');
        const meseroId = parseInt(document.getElementById('meseroId').value || '0');

        const lineas = [];
        document.querySelectorAll('#lineasTable tbody tr').forEach(tr => {
            const platoId = parseInt(tr.querySelector('.plato-select').value || '0');
            const cantidad = parseInt(tr.querySelector('.cantidad-input').value || '1');
            if (platoId > 0 && cantidad > 0) {
                lineas.push({ platoId: platoId, cantidad: cantidad });
            }
        });

        const payload = {
            clienteId: clienteId,
            meseroId: meseroId,
            fecha: new Date().toISOString(),
            lineas: lineas
        };

        const resp = await fetch('/Factura/Create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });

        if (resp.redirected) {
            window.location = resp.url;
        } else {
            alert('Error al crear factura');
        }
    });
</script>